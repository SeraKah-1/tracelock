# TraceLock — Qwen Cloud (DashScope OpenAI-compatible)
# Get a key: https://www.qwencloud.com/  | free quota docs on hackathon resources

# Preferred (hackathon / Qwen Cloud)
DASHSCOPE_API_KEY=
# Optional alias accepted by the client
QWEN_API_KEY=

# OpenAI-compatible base (Alibaba Cloud international DashScope)
# Default used in code when unset:
# https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model for planner (Track 4 Autopilot)
# Examples: qwen-plus, qwen-max, qwen-turbo, qwen3-coder-plus
QWEN_MODEL=qwen-plus

# Force offline fixture loop even if a key is present
TRACELOCK_OFFLINE=0
